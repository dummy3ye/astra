{
  "name": "astra-monorepo",
  "description": "Astra Discord moderation bot monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @astra/bot",
    "start": "npm run start -w @astra/bot",
    "build": "npm run build -w @astra/shared && npm run build -w @astra/bot",
    "deploy": "npm run deploy -w @astra/bot",
    "lint": "eslint packages/",
    "lint:ox": "oxlint packages/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "npm run prisma:generate -w @astra/bot",
    "prisma:migrate": "npm run prisma:migrate -w @astra/bot"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^8.57.1",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.1",
    "semantic-release": "^24.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
