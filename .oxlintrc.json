{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "restriction": "off"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": "warn",
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-require-imports": "error"
  },
  "env": {
    "node": true,
    "es2022": true
  }
}
